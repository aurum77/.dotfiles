{
  "layer": "bottom",
  "position": "bottom",
  "modules-left": ["sway/workspaces", "sway/mode"],
  "modules-center": [],
  "modules-right": ["tray", "custom/media", "memory", "network", "pulseaudio", "battery", "clock"],
  "sway/workspaces": {
    "format": "{name}",
    "disable-scroll-wraparound": true
  },
  "custom/media": {
    "format": "{icon}",
    "return-type": "json",
    "format-icons": {
      "Playing": "َ°ڈ¤",
      "Paused": "َ°گٹ"
    },
    "exec": "playerctl -a metadata --format '{\"tooltip\": \"{{markup_escape(artist)}} - {{markup_escape(title)}}\", \"alt\": \"{{status}}\", \"class\": \"{{status}}\"}' -F",
    "on-click": "playerctl play-pause"
  },
  "memory": {
    "interval": 5,
    "format": "َ°کڑ {used:0.1f} GB",
    "on-click": "/usr/bin/alacritty --class task_manager -e /usr/bin/htop",
    "tooltip": false
  },
  "network": {
    "interval": 3,
    "format": "{icon}",
    "format-wifi": "{icon}",
    "format-ethernet": "{icon}",
    "format-disconnected": "{icon} disconnected",
    "format-linked": "َ°–‚",
    "format-icons": {
      "wifi": ["َ°¤®", "َ°¤¯", "َ°¤ں", "َ°¤¢", "َ°¤¥", "َ°¤¨"],
      "ethernet": "َ°ˆ€",
      "disconnected": "َ°›µ"
    },
    "on-click": "/usr/bin/alacritty --class floating_terminal -e /usr/bin/nmtui-connect",
    "tooltip": true,
    "tooltip-format-wifi": "{essid}: {signalStrength}%",
    "tooltip-format-ethernet": "{ifname}",
    "tooltip-format-linked": "VPN Active",
  },
  "battery": {
    "interval": 60,
    "format": "{icon} {capacity}%",
    "format-full": "{icon}",
    "format-icons": {
      "default": ["َ°‚ژ", "َ°پ؛", "َ°پ»", "َ°پ¼", "َ°پ½", "َ°پ¾", "َ°پ؟", "َ°‚€", "َ°‚پ", "َ°‚‚", "َ°پ¹"],
      "charging": ["َ°¢ں", "َ°¢œ", "َ°‚†", "َ°‚‡", "َ°‚ˆ", "َ°¢‌", "َ°‚‰", "َ°¢‍", "َ°‚ٹ", "َ°‚‹", "َ°‚…"],
      "full": "َ±گ‹"
    },
    "weighted_average": true
  },
  "pulseaudio": {
    "scroll-step": 2,
    "format": "{icon}",
    "format-muted": "َ°£½",
    "format-icons": {
      "default": ["َ°£¾", "َ°£´", "َ°£¶", "َ°£¸", "َ°£؛"]
    },
    "on-click-right": "/usr/bin/alacritty --class floating_terminal -e /usr/bin/pulsemixer",
    "on-click": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
    "tooltip-format": "{desc}: {volume}%",
    "tooltip": true
  },
  "tray": {
    "icon-size": 17,
    "spacing": 25
  },
  "clock": {
    "format": "{:%H:%M}",
    "tooltip-format": "{:%A, %B %d}"
  }
}
